#include<iostream>
using namespace std;

int main()
{
    int n;;
    cout << "Enter number of elements in array : ";
    cin >> n;
    int arr[n];
    cout << "Enter array : " << endl;
    for (int i = 0; i<n ; i++)
    {
        cin >> arr[i];
    }
    cout<< "Your Entered Array : ";
    for (int i = 0; i<n ; i++)
    {
        cout << arr[i] << " ";
    }
    cout << endl;
    int start, end; // 2 pointer approach
    if(n % 2 == 0)
    {
        start = 0;
        end = n-1;
        while(start < end)
        {
            swap(arr[start], arr[end]);
            start++;
            end--;
        }
    }
    else if(n % 2 != 0)
    {
        start = 0;
        end = n-1;
        while(start <= end)
        {
            swap(arr[start], arr[end]);
            start++;
            end--;
        }
    }
    cout << "Reversed Array : ";
    for (int i = 0; i<n ; i++)
    {
        cout << arr[i] << " ";
    }
    
}
